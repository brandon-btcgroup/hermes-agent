# Environment file for simplex-chat-hermes.container (Quadlet).
#
# Copy to ~/.config/containers/systemd/simplex-chat-hermes.env and fill in.
# Both URLs must include the cert fingerprint AND the basic-auth token,
# in the form:
#   <proto>://<base64-fingerprint>:<auth-token>@<host>:<port>
#
# Find the canonical URLs in your server config. For smp-server:
#   /etc/opt/simplex/smp-server.ini   (look for: server_address)
# For xftp-server:
#   /etc/opt/simplex-xftp/file-server.ini

# SMP server (messages). Clearnet or .onion both work.
SMP_SERVER=smp://YOUR-SMP-FINGERPRINT=:YOUR-SMP-AUTH-TOKEN@smp.example.com:5223

# XFTP server (file transfer). Required for image / file / voice / video.
# Drop this and the matching --xftp-server line in the Quadlet to use
# SimpleX's public XFTP servers (xftp1.simplex.im, xftp2.simplex.im, ...).
XFTP_SERVER=xftp://YOUR-XFTP-FINGERPRINT=:YOUR-XFTP-AUTH-TOKEN@xftp.example.com:5225
